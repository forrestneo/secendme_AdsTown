{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "memorySize": 256,
      "timeout": 30
    }
  },
  "build": {
    "command": "pip install -r requirements.txt"
  }
}
